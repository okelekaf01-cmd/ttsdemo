generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  displayName  String
  createdAt    DateTime   @default(now())
  pointLogs    PointLog[]
}

model PointLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  delta     Int
  source    String
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, createdAt])
}
